# ── Server ────────────────────────────────────────────────────────────────────
PORT=8080
NODE_ENV=production

# ── Database (use Cloud SQL or PlanetScale values in production) ───────────────
DB_HOST=127.0.0.1          # Cloud SQL: use unix socket path in production (see below)
DB_PORT=3306
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_NAME=toastmasters_db

# Cloud SQL Unix socket example (when running on Cloud Run):
# DB_HOST=/cloudsql/PROJECT_ID:REGION:INSTANCE_NAME
# DB_PORT=        ← leave blank when using unix socket

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins (no trailing slash)
# Leave empty to allow all origins (dev only)
ALLOWED_ORIGINS=https://your-frontend-domain.com

# ── Email (Gmail App Password) ────────────────────────────────────────────────
EMAIL_USER=your_gmail@gmail.com
EMAIL_PASS=your_16_char_app_password

# ── Admin ─────────────────────────────────────────────────────────────────────
ADMIN_EMAIL=admin@yourdomain.com

# ── Backend public URL (used in email one-click links) ────────────────────────
BASE_URL=https://your-cloud-run-service-url.run.app

# ── Google Sheets Webhook Sync ────────────────────────────────────────────────
# Google Apps Script Web App URL for live sheets sync (Approach A)
GOOGLE_SHEETS_WEBHOOK_URL=https://script.google.com/macros/s/XXXXX/exec

# ── Admin Dashboard Password Protection ───────────────────────────────────────
ADMIN_PASSWORD=your_admin_secret_password
